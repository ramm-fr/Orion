<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.orion.player</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Orion</name>
  <summary>A powerful, modern video player for Linux</summary>
  <developer id="com.orion.player">
    <name>Ram</name>
  </developer>

  <description>
    <p>
      Orion is a feature-rich video player built with GTK4 and GStreamer for the Linux desktop.
      It supports over 80 video formats and offers advanced playback features in a clean,
      modern interface that follows GNOME design guidelines.
    </p>
    <p>Key Features:</p>
    <ul>
      <li>80+ video format support (MP4, MKV, AVI, MOV, WebM, FLV, and more)</li>
      <li>Stream playback — HLS (.m3u8), RTSP, HTTP/HTTPS URLs</li>
      <li>Multi-audio track selection with automatic language detection</li>
      <li>Embedded subtitle track switching</li>
      <li>Online subtitle search and download</li>
      <li>10-band audio equalizer with 9 presets</li>
      <li>Aspect ratio control (Default, Fill, Stretch, Fit)</li>
      <li>Playback speed control (0.25x to 4.0x)</li>
      <li>Video folders — organize videos in custom collections</li>
      <li>Drag and drop file support</li>
      <li>Statistics dashboard with real-time activity graphs</li>
      <li>Screenshot capture</li>
      <li>Keyboard shortcuts for all controls</li>
      <li>Hardware acceleration</li>
      <li>AB repeat and frame stepping</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.orion.player.desktop</launchable>

  <url type="homepage">https://github.com/orion-player/orion</url>
  <url type="bugtracker">https://github.com/orion-player/orion/issues</url>

